OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
OPENAI_MODEL=deepseek-reasoner

# --- Memory Compression ---
MEMORY_SUMMARY_MODEL=deepseek-reasoner
MEMORY_TOKEN_THRESHOLD=8000
MEMORY_RECENT_K=40

# --- WeChat ClawBot ---
# 凭据通过 `python wechat.py setup` 扫码获取，自动保存至 ~/.claude/channels/wechat/account.json
# 无需在此手动配置 token
